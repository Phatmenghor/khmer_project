<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- Production-ready logging: INFO level only, async appender for performance -->
  <!-- GlobalLoggingAspect: All operations logged automatically -->

  <property name="LOG_PATH" value="logs"/>
  <property name="LOG_FILE" value="${LOG_PATH}/application"/>
  <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n"/>
  <property name="CONSOLE_PATTERN" value="%d{HH:mm:ss} %-5level %msg%n"/>

  <!-- ============ APPENDERS ============ -->

  <!-- Console: Simple, minimal format -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- File: Rolling daily, max 10MB per file -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_FILE}.log</file>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_FILE}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- Errors only: Separate error file for monitoring -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/error.log</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- Async: Non-blocking, high-performance logging -->
  <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>512</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <includeCallerData>false</includeCallerData>
    <appender-ref ref="FILE"/>
    <appender-ref ref="ERROR_FILE"/>
  </appender>

  <!-- ============ LOGGERS ============ -->

  <!-- Application: INFO level -->
  <logger name="com.emenu" level="INFO"/>

  <!-- Global Logging Aspect: INFO level -->
  <logger name="com.emenu.features.shared.aspect.GlobalLoggingAspect" level="INFO"/>

  <!-- Framework: WARN level to reduce noise -->
  <logger name="org.springframework" level="WARN"/>
  <logger name="org.springframework.boot" level="WARN"/>
  <logger name="org.springframework.security" level="WARN"/>
  <logger name="org.springframework.web" level="WARN"/>
  <logger name="org.hibernate" level="WARN"/>
  <logger name="com.zaxxer.hikari" level="WARN"/>
  <logger name="org.postgresql" level="WARN"/>

  <!-- ============ ROOT LOGGER ============ -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ASYNC"/>
  </root>

  <!-- ============ PROFILES ============ -->

  <!-- Development: More details -->
  <springProfile name="dev">
    <logger name="com.emenu" level="DEBUG"/>
    <root level="DEBUG">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

  <!-- Production: Minimal overhead -->
  <springProfile name="prod">
    <root level="INFO">
      <appender-ref ref="ASYNC"/>
    </root>
  </springProfile>

  <!-- Test: Errors only -->
  <springProfile name="test">
    <root level="ERROR">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

</configuration>